        function ValidateAlpha(evt) {
            // alert(evt.keyCode);
            // alert(evt.which);
            var keyCode = (evt.which) ? evt.which : evt.keyCode

            if ((keyCode < 65 || keyCode > 90) && (keyCode < 97 || keyCode > 122) && keyCode != 32 && (keyCode < 222 || keyCode > 218))

                return false;
            return true;
        }
    </script>
