            //}

            function downloadImageusingd2i_1(value) {
                var container = document.getElementById(value);

                // Use dom-to-image to capture the content
                domtoimage.toBlob(container)
                    .then(function (blob) {
                        // Create a temporary link and trigger the download
                        var link = document.createElement("a");
                        link.download = value; // Set the image filename
                        link.href = window.URL.createObjectURL(blob);
                        link.click();
                    })
                    .catch(function (error) {
                        console.error("Error capturing image: " + error);
                    });
            }


            function downloadImageusingd2i(value) {
                var container = document.getElementById(value);

                html2canvas(container, {
                    allowTaint: true,
                    backgroundColor: null // Set the background color to transparent
                }).then(function (canvas) {
                    var link = document.createElement("a");
                    document.body.appendChild(link)
                        ;
                    link.download = value + ".png";
                    link.href = canvas.toDataURL("image/png");
                    link.target = '_blank';
                    link.click();
                });
            }
        </script>

